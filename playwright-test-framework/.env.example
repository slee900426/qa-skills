# Copy this file to ".env" and adjust as needed.
# Loaded automatically by playwright.config.ts via dotenv.

# Base URL for the SauceDemo public-site tests.
SAUCEDEMO_BASE_URL=https://www.saucedemo.com

# Local port used by the http-server that serves demo-app/ (self-contained demo).
# Must be free on your machine; playwright.config.ts starts/stops the server for you.
DEMO_PORT=4173
